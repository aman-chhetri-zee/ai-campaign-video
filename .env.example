# ===========================================
# CREATIFY AI - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -----------------
# Google Cloud / Vertex AI
# -----------------
# Path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./vertex-tester.json

# GCP Project Configuration
GCP_PROJECT_ID=creatoreconomy-479409
GCP_LOCATION=us-central1

# Available Models:
# - gemini-2.5-pro (text generation)
# - gemini-3-pro-image (Nano Banana Pro - image generation)

# -----------------
# GCP Cloud Storage (for production file uploads)
# -----------------
# GCP_BUCKET_NAME=creatify-uploads

# -----------------
# App Config
# -----------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------
# Kling AI
# -----------------
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE=https://api.klingai.com

# Default video gen model. Use kling-v1-6 for camera_control support.
KLING_MODEL_ID=kling-v1-6

# Optional: enable Kling Motion Control product (requires v2.6+ account access)
KLING_USE_MOTION_CONTROL=false
KLING_MOTION_CONTROL_MODEL=kling-v2-6

# -----------------
# Vercel
# -----------------
# Vercel deployment URL — used as the base for serving the template video to Kling Motion Control
VERCEL_DEPLOYMENT_URL=https://ai-campaign-video.vercel.app

# Vercel Blob token — get from Vercel project → Storage → Blob → connect to local
# Required only when KLING_USE_MOTION_CONTROL=true
BLOB_READ_WRITE_TOKEN=

# -----------------
# Seedance 2.0 (BytePlus / Volcengine Ark) — alternative to Kling Motion Control
# -----------------
# Set USE_SEEDANCE=true to route video generation through Seedance 2.0 instead of Kling.
# Kling stays intact; this is a runtime A/B flag, not a code branch.
USE_SEEDANCE=false
SEEDANCE_API_KEY=
SEEDANCE_API_BASE=https://ark.ap-southeast.bytepluses.com
SEEDANCE_MODEL_ID=dreamina-seedance-2-0-260128

# Nano Banana — Gemini image generation model used for Seedance keyframes.
# Produces stylized AI-illustration keyframes to bypass Seedance's privacy filter.
# Probed winner: gemini-2.5-flash-image (also try gemini-2.5-flash-image-preview, gemini-2.0-flash-exp)
NANO_BANANA_MODEL=

# -----------------
# Feature Flags
# -----------------
# Set to 'true' to use mock APIs instead of real Vertex AI
USE_MOCK_API=false
