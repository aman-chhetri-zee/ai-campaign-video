# =============================================================================
# AI Campaign Video pipeline — environment variables
# Copy this file to .env.local (or your runtime equivalent) and fill in values.
# =============================================================================

# ─── Google Vertex AI (REQUIRED — keyframes + image gen + Gemini analysis) ──
# Path to a service-account JSON key with these IAM roles on the project:
#   - roles/aiplatform.user
#   - roles/storage.objectViewer (if reading from GCS)
GOOGLE_APPLICATION_CREDENTIALS=./vertex-tester.json

# Vertex project + location. The keyframe + master-subject calls hit the
# Nano Banana Pro model (gemini-3-pro-image-preview) which is currently
# only served from the "global" location regardless of GCP_LOCATION.
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ─── kie.ai (REQUIRED — primary video generation provider) ──────────────────
# Sign up at https://kie.ai and create an API key. Each video clip costs
# roughly $0.40 (4–15s at 720p). Top up the account before running probes.
KIE_API_KEY=
# Optional overrides (defaults shown).
KIE_API_BASE=https://api.kie.ai
KIE_MODEL_ID=bytedance/seedance-2
KIE_RESOLUTION=720p

# Switch between two video generation strategies for kie.ai:
#   multishot_single_call (default) — one kie.ai call per outfit_segment;
#                                     all keyframes + reference video sent
#                                     together. Cheapest, output duration
#                                     matches template.
#   per_shot_conform                — one kie.ai call per look, ffmpeg
#                                     speed-conforms each clip to the
#                                     segment's true span. More API calls.
KIE_VIDEO_STRATEGY=multishot_single_call

# ─── Vercel Blob (REQUIRED — kie.ai fetches keyframes via HTTPS URLs) ───────
# Get this from https://vercel.com/dashboard/stores → create a Blob store →
# .env.local → BLOB_READ_WRITE_TOKEN.
BLOB_READ_WRITE_TOKEN=

# Public deployment URL where the catalog (templates + products) is hosted.
# kie.ai/Seedance fetches reference_video and product reference images from
# these URLs. If you're running locally and your assets are NOT yet deployed,
# use the override env vars below.
VERCEL_DEPLOYMENT_URL=https://ai-campaign-video.vercel.app

# Per-template / per-product URL overrides for assets that aren't on the
# production deployment yet. JSON map of product_id → blob URL.
# MOTION_REFERENCE_URL_OVERRIDE replaces the template video URL entirely.
MOTION_REFERENCE_URL_OVERRIDE=
PRODUCT_URL_OVERRIDES=

# ─── Provider switch ────────────────────────────────────────────────────────
# kie_seedance (default) | seedance | kling
# The recommended provider is kie_seedance — the others are kept for
# fallback / experimentation and need their own credentials below.
VIDEO_PROVIDER=kie_seedance

# ─── Direct Seedance / BytePlus Ark (OPTIONAL fallback) ─────────────────────
# Only required if VIDEO_PROVIDER=seedance.
SEEDANCE_API_KEY=
SEEDANCE_API_BASE=https://ark.ap-southeast.bytepluses.com
SEEDANCE_MODEL_ID=dreamina-seedance-2-0-260128
SEEDANCE_FIRST_FRAME_ONLY=false
USE_SEEDANCE=false

# ─── Kling (OPTIONAL — legacy fallback for image-to-video) ──────────────────
# Only required if VIDEO_PROVIDER=kling.
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE=https://api-singapore.klingai.com
KLING_MODEL_ID=kling-v1
KLING_MOTION_CONTROL_MODEL=kling-v2-6
KLING_USE_MOTION_CONTROL=true

# ─── Pipeline flags ─────────────────────────────────────────────────────────
# Stop after keyframe generation, skip video calls and concat. Useful for
# image-quality testing without burning kie.ai credits.
SKIP_KLING=false
